# .env dosyasını asla git'e yükleme — .gitignore'a ekle

# Sunucu
PORT=3000

# Admin paneli erişim token'ı (değiştir!)
ADMIN_TOKEN=guclu-bir-sifre-yaz

# Supabase — https://supabase.com > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# E-posta ayarları (nodemailer — Gmail örneği)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=mailadresi@gmail.com
# Gmail için: Hesap > Güvenlik > Uygulama Şifresi (2FA açık olmalı)
MAIL_PASS=xxxx-xxxx-xxxx-xxxx
# Teklif bildirimleri nereye gönderilsin?
MAIL_TO=sahip@sirket.com
